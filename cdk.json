{
  "app": "python3 cdk/app.py",
  "watch": {
    "include": [
      "cdk/**",
      "backend/**",
      "shared/**"
    ],
    "exclude": [
      "**/__pycache__",
      "**/.pytest_cache",
      "**/node_modules",
      "**/.venv"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": [
      "aws",
      "aws-cn"
    ]
  }
}
